import os
from sqlalchemy import create_engine, text
from sqlalchemy.orm import sessionmaker, declarative_base
from sqlalchemy.engine import make_url


# Load DATABASE_URL from environment (same default as config)
DATABASE_URL = os.getenv(
    "DATABASE_URL",
    "postgresql://ello:ello123@db:5432/ello_db"
)


def _ensure_postgres_db_exists(database_url: str) -> None:
    """Ensure the target Postgres database exists. If it does not, create it.

    This function is no-op for non-postgres URLs.
    """
    try:
        url = make_url(database_url)
    except Exception:
        return

    if not url.drivername.startswith("postgres"):
        return

    target_db = url.database
    if not target_db:
        return

    # Connect to default maintenance DB to check/create the target DB
    maintenance_db = "postgres"
    maintenance_url = url.set(database=maintenance_db)
    eng = create_engine(maintenance_url)
    try:
        with eng.connect() as conn:
            exists = conn.execute(
                text("SELECT 1 FROM pg_database WHERE datname = :d"),
                {"d": target_db},
            ).scalar()
            if not exists:
                # CREATE DATABASE cannot run inside a transaction block
                conn = conn.execution_options(isolation_level="AUTOCOMMIT")
                conn.execute(text(f'CREATE DATABASE "{target_db}"'))
    finally:
        eng.dispose()


# Ensure DB exists before creating an engine bound to it
_ensure_postgres_db_exists(DATABASE_URL)

engine = create_engine(
    DATABASE_URL,
    pool_pre_ping=True,
)

SessionLocal = sessionmaker(
    autocommit=False,
    autoflush=False,
    bind=engine,
)

Base = declarative_base()


def get_db():
    db = SessionLocal()
    try:
        yield db
    finally:
        db.close()
