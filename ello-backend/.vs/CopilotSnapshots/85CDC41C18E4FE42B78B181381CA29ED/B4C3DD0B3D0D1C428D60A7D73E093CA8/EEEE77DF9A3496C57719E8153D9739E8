from pydantic import BaseModel
from datetime import datetime


class VibeCreate(BaseModel):
    video_url: str
    caption: str | None = None


class VibeResponse(BaseModel):
    id: int
    video_url: str
    caption: str | None
    user_id: int
    created_at: datetime

    class Config:
        orm_mode = True