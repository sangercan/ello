from pydantic import BaseModel
from datetime import datetime


class StoryCreate(BaseModel):
    media_url: str


class StoryResponse(BaseModel):
    id: int
    user_id: int
    media_url: str
    created_at: datetime
    expires_at: datetime

    class Config:
        orm_mode = True