from pydantic import BaseModel
from datetime import datetime


class CommentCreate(BaseModel):
    content_type: str
    content_id: int
    text: str


class CommentResponse(BaseModel):
    id: int
    user_id: int
    content_type: str
    content_id: int
    text: str
    created_at: datetime

    class Config:
        orm_mode = True