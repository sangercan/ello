POSTGRES_USER=ello
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_STRONG_PASSWORD
POSTGRES_DB=ello_db
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET
ALLOWED_ORIGINS=https://ellosocial.com,https://www.ellosocial.com
PUSH_NOTIFICATIONS_ENABLED=true
# Use one of the two options below:
# FIREBASE_CREDENTIALS_FILE=/run/secrets/firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}

# Browser Web Push (VAPID)
# WEB_PUSH_VAPID_PUBLIC_KEY=<public key for browser subscribe>
# WEB_PUSH_VAPID_PRIVATE_KEY=<private key for backend send>
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@ellosocial.com

# Email (Titan SMTP)
EMAIL_ENABLED=true
EMAIL_SMTP_HOST=smtp.titan.email
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_TLS=true
EMAIL_SMTP_USE_SSL=false
EMAIL_SMTP_TIMEOUT_SECONDS=20
EMAIL_SMTP_USERNAME=
EMAIL_SMTP_PASSWORD=
EMAIL_FROM_SUPPORT=support@ellosocial.com
EMAIL_FROM_NOREPLY=noreply@ellosocial.com
EMAIL_REPLY_TO_SUPPORT=support@ellosocial.com
FRONTEND_BASE_URL=https://ellosocial.com
PASSWORD_RESET_EXPIRE_MINUTES=30

# Optional but recommended
ENVIRONMENT=production
DEBUG=false

# Frontend/WebRTC
VITE_API_URL=/api
VITE_STUN_URL=stun:stun.l.google.com:19302,stun:global.stun.twilio.com:3478
VITE_TURN_URL=turn:ellosocial.com:3478?transport=udp,turn:ellosocial.com:3478?transport=tcp
VITE_TURN_USER=elloturn
VITE_TURN_PASS=CHANGE_ME_TURN_PASSWORD
# If you need to force a different WS endpoint (rare):
# VITE_WS_URL=https://ellosocial.com/api

# Browser web push key used at frontend build-time
# VITE_WEB_PUSH_VAPID_PUBLIC_KEY=<same as WEB_PUSH_VAPID_PUBLIC_KEY>

# TURN server (coturn)
TURN_PUBLIC_IP=129.121.36.183
TURN_REALM=ellosocial.com
TURN_USER=elloturn
TURN_PASS=CHANGE_ME_TURN_PASSWORD
